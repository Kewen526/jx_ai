# 指数退避重试装饰器
# ============================================================
def exponential_backoff_retry(max_retries: int = 10, base_wait: float = 2, max_wait: float = 60):
    def decorator(func):
        @wraps(func)
        async def wrapper(*args, **kwargs):
            for attempt in range(max_retries):
                try:
                    result = await func(*args, **kwargs)
                    if isinstance(result, str) and '失败' in result:
                        raise Exception(f"返回失败结果: {result}")
                    return result
                except ContentFilterError:
                    # 敏感词错误不重试，直接抛出
                    raise
                except Exception as e:
                    attempt_num = attempt + 1
                    logger.error(f"❌ 第{attempt_num}/{max_retries}次尝试失败: {str(e)[:200]}")
                    if attempt == max_retries - 1:
                        raise Exception(f"重试{max_retries}次后仍失败: {str(e)}")
                    wait_time = min(base_wait * (2 ** attempt), max_wait)
                    logger.warning(f"⏳ 等待{wait_time}秒后进行第{attempt_num + 1}次重试...")
                    await asyncio.sleep(wait_time)
            raise Exception(f"重试{max_retries}次后仍失败")
        return wrapper
    return decorator


