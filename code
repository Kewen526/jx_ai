{{"passed": true或false, "checks": [{{"id": 1, "name": "技师编号虚构", "result": "✅通过 或 ❌不合格", "detail": "说明"}}, {{"id": 2, "name": "占位符残留", "result": "✅通过 或 ❌不合格", "detail": "说明"}}, {{"id": 3, "name": "凭空推荐项目", "result": "✅通过 或 ❌不合格", "detail": "说明"}}, {{"id": 4, "name": "条件句外露", "result": "✅通过 或 ❌不合格", "detail": "说明"}}, {{"id": 5, "name": "星级语气匹配", "result": "✅通过 或 ❌不合格", "detail": "说明"}}, {{"id": 6, "name": "信息编造", "result": "✅通过 或 ❌不合格", "detail": "说明"}}, {{"id": 7, "name": "回复长度", "result": "✅通过 或 ⚠️警告", "detail": "实际X字"}}], "fixed_reply": "如果不合格，提供修正后的回复；如果合格，填null"}}

## 审核原则

1. 宁严勿松：有疑问的一律标记不合格
2. 修正最小化：修正时只删除/改写违规部分，保留原回复中合格的内容和风格
3. 修正后的回复必须通过所有检查项
4. 直接输出JSON结果，无需其他解释
"""


# ============================================================
# AI调用函数
# ============================================================
@exponential_backoff_retry(max_retries=10, base_wait=2, max_wait=60)
async def call_zhipuai(
        session_manager: SessionManager,
        prompt: str,
        system_prompt: str = None,
        model: str = "glm-4.7-flash",
        temperature: float = 0.1,
        max_tokens: int = 4096
) -> str:
    """调用智谱AI"""
    selected_key = key_manager.get_next_available_key(ZHIPUAI_API_KEYS)

    if not selected_key:
        logger.warning("⚠️ 所有密钥都在黑名单中，等待30秒...")
        await asyncio.sleep(30)
        selected_key = key_manager.get_next_available_key(ZHIPUAI_API_KEYS)
        if not selected_key:
            raise Exception("所有密钥都不可用")

    try:
        url = "https://open.bigmodel.cn/api/paas/v4/chat/completions"
        headers = {
            "Authorization": f"Bearer {selected_key}",
            "Content-Type": "application/json"
        }

        messages = []
        if system_prompt:
            messages.append({"role": "system", "content": system_prompt})
        messages.append({"role": "user", "content": prompt})

        payload = {
            "model": model,
            "messages": messages,
            "temperature": temperature,
            "max_tokens": max_tokens
        }

        session = await session_manager.get_session()

        async with session.post(url, headers=headers, json=payload, timeout=120) as response:
            if response.status == 200:
                result = await response.json()
                if 'choices' in result and len(result['choices']) > 0:
                    content = result['choices'][0]['message']['content']
                    key_manager.record_success(selected_key)
                    return content
                else:
                    raise Exception(f"响应格式错误: {result}")
            else:
                response_text = await response.text()
                key_manager.record_failure(selected_key, f"HTTP {response.status}: {response_text}")
                # 检测1301敏感词错误
                if '"code":"1301"' in response_text or '"1301"' in response_text:
                    logger.warning(f"⚠️ 检测到敏感词过滤(1301)，不再重试")
                    raise ContentFilterError("内容包含敏感词，被过滤")
                # 429限流 - 抛出异常触发指数退避重试
                if response.status == 429:
                    logger.warning(f"⚠️ 429限流，将自动重试 (密钥: ...{selected_key[-8:]})")
                raise Exception(f"API调用失败: HTTP {response.status}")

    except ContentFilterError:
        raise
    except Exception as e:
        key_manager.record_failure(selected_key, str(e))
        raise


# ============================================================
# 质检审核函数
# ============================================================
async def check_reply_quality(
        session_manager: SessionManager,
        task: 'ReviewTask',
        ai_reply: str
) -> str:
    """质检审核AI生成的回复，返回最终使用的回复"""
    task_id = f"[{task.table_name}][{task.id}]"

    try:
        qc_prompt = QC_PROMPT_TEMPLATE.format(
            shop_name=task.shop_name,
            star=task.star,
            content=task.content,
            product_name=task.product_name,
            reply=ai_reply
        )

        qc_response = await call_zhipuai(
            session_manager=session_manager,
            prompt=qc_prompt,
            system_prompt=QC_SYSTEM_PROMPT,
            temperature=0.1
        )

        # 尝试从响应中提取JSON（可能包含markdown代码块）
        json_text = qc_response.strip()
        # 去除可能的markdown代码块标记
        json_match = re.search(r'```(?:json)?\s*([\s\S]*?)\s*```', json_text)
        if json_match:
            json_text = json_match.group(1)

        qc_result = json.loads(json_text)

        if qc_result.get("passed", True):
            logger.info(f"✅ 质检通过 {task_id}")
            return ai_reply
        else:
            # 质检不通过，记录不合格项
            failed_checks = [
                c for c in qc_result.get("checks", [])
                if "❌" in c.get("result", "")
            ]
            failed_names = [c.get("name", "未知") for c in failed_checks]
            logger.warning(f"⚠️ 质检不通过 {task_id}: {', '.join(failed_names)}")

            # 使用修正后的回复
            fixed_reply = qc_result.get("fixed_reply")
            if fixed_reply and fixed_reply != "null" and isinstance(fixed_reply, str):
                logger.info(f"🔧 使用质检修正回复 {task_id}")
                return fixed_reply
            else:
                logger.warning(f"⚠️ 质检无修正回复，使用原回复 {task_id}")
                return ai_reply

    except json.JSONDecodeError as e:
        logger.warning(f"⚠️ 质检JSON解析失败 {task_id}: {str(e)[:100]}，使用原回复")
        return ai_reply
    except Exception as e:
        logger.warning(f"⚠️ 质检调用失败 {task_id}: {str(e)[:100]}，使用原回复")
        return ai_reply


# ============================================================
# 数据库操作
# ============================================================
async def get_pending_reviews(pool: aiomysql.Pool) -> List[ReviewTask]:
    """获取所有待处理的评论"""
    tasks = []

    async with pool.acquire() as conn:
        async with conn.cursor(aiomysql.DictCursor) as cursor:
            # 查询美团表（有product_name）
            meituan_sql = """
                SELECT id, shop_id, shop_name, star_display, content, product_name
                FROM review_detail_meituan
                WHERE shop_reply = '暂无回复' AND ai_gen IS NULL
            """
            await cursor.execute(meituan_sql)
            meituan_rows = await cursor.fetchall()

            for row in meituan_rows:
                tasks.append(ReviewTask(
                    table_name="review_detail_meituan",
                    id=row['id'],
                    shop_id=str(row['shop_id']) if row.get('shop_id') else "",
                    shop_name=row['shop_name'] or "未知店铺",
                    star=int(row['star_display']) if row.get('star_display') else 5,
                    content=row['content'] if row['content'] else "无",
                    product_name=row['product_name'] if row['product_name'] else "无"
                ))

            logger.info(f"📋 美团表待处理: {len(meituan_rows)} 条")

            # 查询大众点评表（无product_name）
            dianping_sql = """
                SELECT id, shop_id, shop_name, star_display, content
                FROM review_detail_dianping
                WHERE shop_reply = '暂无回复' AND ai_gen IS NULL
            """
            await cursor.execute(dianping_sql)
            dianping_rows = await cursor.fetchall()

            for row in dianping_rows:
                tasks.append(ReviewTask(
                    table_name="review_detail_dianping",
                    id=row['id'],
                    shop_id=str(row['shop_id']) if row.get('shop_id') else "",
                    shop_name=row['shop_name'] or "未知店铺",
                    star=int(row['star_display']) if row.get('star_display') else 5,
                    content=row['content'] if row['content'] else "无",
                    product_name="无"  # 点评表没有团购信息
                ))

            logger.info(f"📋 点评表待处理: {len(dianping_rows)} 条")

    logger.info(f"📋 总计待处理: {len(tasks)} 条")
    return tasks


async def update_ai_reply(pool: aiomysql.Pool, table_name: str, record_id: int, ai_reply: str) -> bool:
    """更新AI回复到数据库"""
    try:
        async with pool.acquire() as conn:
            async with conn.cursor() as cursor:
                sql = f"UPDATE {table_name} SET ai_gen = %s WHERE id = %s"
                await cursor.execute(sql, (ai_reply, record_id))
                await conn.commit()
                return True
    except Exception as e:
        logger.error(f"❌ 更新数据库失败 [{table_name}][{record_id}]: {e}")
        return False


async def get_review_ending(pool: aiomysql.Pool, shop_id: str) -> Optional[str]:
    """根据门店ID查询评价结尾文案"""
    if not shop_id:
        return None
    try:
        async with pool.acquire() as conn:
            async with conn.cursor(aiomysql.DictCursor) as cursor:
                sql = "SELECT review_ending FROM store_strategy_config WHERE store_id = %s"
                await cursor.execute(sql, (shop_id,))
                row = await cursor.fetchone()
                if row and row.get('review_ending'):
                    return row['review_ending']
                return None
    except Exception as e:
        logger.error(f"❌ 查询评价结尾失败 [shop_id={shop_id}]: {e}")
        return None


# ============================================================
# 任务处理
# ============================================================
async def process_single_task(
        task: ReviewTask,
        session_manager: SessionManager,
        pool: aiomysql.Pool,
        semaphore: asyncio.Semaphore
) -> Dict[str, Any]:
    """处理单个评论任务"""
    async with semaphore:
        task_id = f"[{task.table_name}][{task.id}]"

        try:
            # 构建提示词
            prompt = PROMPT_TEMPLATE.format(
                shop_name=task.shop_name,
                star=task.star,
                content=task.content,
                product_name=task.product_name
            )

            # 调用AI生成回复
            logger.info(f"🤖 处理中 {task_id} - {task.shop_name[:20]}...")
            ai_reply = await call_zhipuai(
                session_manager=session_manager,
                prompt=prompt,
                system_prompt=SYSTEM_PROMPT
            )

            # 质检审核
            logger.info(f"🔍 质检中 {task_id}...")
            ai_reply = await check_reply_quality(session_manager, task, ai_reply)

            # 查询并拼接评价结尾
            review_ending = await get_review_ending(pool, task.shop_id)
            if review_ending:
                ai_reply = ai_reply.rstrip() + review_ending
                logger.info(f"📎 已拼接评价结尾 {task_id}")

            # 写入数据库
            success = await update_ai_reply(pool, task.table_name, task.id, ai_reply)

            if success:
                logger.info(f"✅ 完成 {task_id} - 回复长度: {len(ai_reply)}字")
                return {"id": task.id, "table": task.table_name, "status": "success", "reply_length": len(ai_reply)}
            else:
                return {"id": task.id, "table": task.table_name, "status": "db_error"}

        except ContentFilterError:
            # 敏感词错误，写入固定文本
            logger.warning(f"⚠️ 敏感词 {task_id} - 写入固定提示")
            fixed_reply = "包含敏感词，无法生成"
            success = await update_ai_reply(pool, task.table_name, task.id, fixed_reply)
            if success:
                return {"id": task.id, "table": task.table_name, "status": "filtered", "reply_length": len(fixed_reply)}
            else:
                return {"id": task.id, "table": task.table_name, "status": "db_error"}

        except Exception as e:
            logger.error(f"❌ 失败 {task_id}: {str(e)[:100]}")
            return {"id": task.id, "table": task.table_name, "status": "error", "error": str(e)[:200]}


async def main():
    """主函数"""
    logger.info("=" * 60)
    logger.info("🚀 AI评论回复生成器启动")
    logger.info("=" * 60)

    # 创建数据库连接池
    pool = await aiomysql.create_pool(**DB_CONFIG, minsize=2, maxsize=10)
    session_manager = SessionManager()
    semaphore = asyncio.Semaphore(MAX_CONCURRENT)

    try:
        # 获取待处理任务
        tasks = await get_pending_reviews(pool)

        if not tasks:
            logger.info("✅ 没有待处理的评论，退出")
            return

        # 并发处理所有任务
        start_time = time.time()

        results = await asyncio.gather(*[
            process_single_task(task, session_manager, pool, semaphore)
            for task in tasks
        ])

        # 统计结果
        elapsed = time.time() - start_time
        success_count = sum(1 for r in results if r['status'] == 'success')
        filtered_count = sum(1 for r in results if r['status'] == 'filtered')
        error_count = sum(1 for r in results if r['status'] not in ('success', 'filtered'))

        logger.info("=" * 60)
        logger.info(f"🏁 处理完成!")
        logger.info(f"   总计: {len(tasks)} 条")
        logger.info(f"   成功: {success_count} 条")
        logger.info(f"   敏感词: {filtered_count} 条")
        logger.info(f"   失败: {error_count} 条")
        logger.info(f"   耗时: {elapsed:.1f} 秒")
        logger.info("=" * 60)

        # 输出失败记录
        if error_count > 0:
            logger.warning("❌ 失败记录:")
            for r in results:
                if r['status'] != 'success':
                    logger.warning(f"   - [{r['table']}][{r['id']}]: {r.get('error', r['status'])}")

    finally:
        await session_manager.close()
        pool.close()
        await pool.wait_closed()


if __name__ == "__main__":
    asyncio.run(main())
